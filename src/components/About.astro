---
import type { Locale } from "../i18n/config";
import { t } from "../i18n/ui";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section id="about" class="section about">
  <div class="section-title">{t("about.title", lang)}</div>
  <p>{t("about.body", lang)}</p>
</section>
