---
import { Image } from "astro:assets";
import { galleryItems } from "../data/gallery";
import type { Locale } from "../i18n/config";
import { t } from "../i18n/ui";
import { pick } from "../i18n/utils";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<section id="gallery" class="section">
  <div class="section-title">{t("gallery.title", lang)}</div>

  <div class="gallery">
    {
      galleryItems.map((item) => {
        const href = item.href ? `${baseUrl}${lang}/${item.href}` : undefined;
        return (
          <a
            class={`gallery-card${item.comingSoon ? " is-skeleton" : ""}`}
            aria-disabled={item.comingSoon}
            href={href}
          >
            <div class="gallery-thumb">
              {item.thumb && (
                <Image src={item.thumb} alt={pick(item.title, lang)} />
              )}
            </div>
            <div class="gallery-meta">
              <span class="gallery-badge">{pick(item.status, lang)}</span>
              <h3>{pick(item.title, lang)}</h3>
              <p>{pick(item.description, lang)}</p>
            </div>
          </a>
        );
      })
    }
  </div>
</section>
