---
import { locales, localeLabels, type Locale } from "../i18n/config";
import { localizedPath } from "../i18n/utils";
import { t } from "../i18n/ui";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<header>
  <div class="logo">AGITO</div>

  <nav>
    <a href="#service">{t("nav.service", lang)}</a>
    <a href="#artwork">{t("nav.artwork", lang)}</a>
    <a href="#gallery">{t("nav.gallery", lang)}</a>
    <a href="#members">{t("nav.members", lang)}</a>
    <a href="#about">{t("nav.about", lang)}</a>
  </nav>

  <div class="lang-switcher" aria-label="Language">
    <button
      type="button"
      class="lang-switcher__toggle"
      aria-haspopup="menu"
      aria-expanded="false"
      aria-label={localeLabels[lang]}
    >
      <svg
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M3 12h18"></path>
        <path d="M12 3a14 14 0 0 1 0 18"></path>
        <path d="M12 3a14 14 0 0 0 0 18"></path>
      </svg>
    </button>
    <ul class="lang-switcher__menu" role="menu">
      {
        locales.map((l) => (
          <li role="none">
            <a
              role="menuitem"
              href={localizedPath(l)}
              class:list={["lang-switcher__item", { "is-active": l === lang }]}
              aria-current={l === lang ? "page" : undefined}
              hreflang={l}
            >
              {localeLabels[l]}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>
