---
import type { Locale } from "../i18n/config";
import { t } from "../i18n/ui";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section class="hero">
  <h1 set:html={t("hero.title", lang)} />
  <p>{t("hero.lead", lang)}</p>
  <a href="#artwork" class="button">{t("hero.cta", lang)}</a>
</section>
